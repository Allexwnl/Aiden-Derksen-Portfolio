# Firebase (client) — kopieer naar .env en vul in vanuit Firebase Console > Projectinstellingen
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# LET OP: de GitHub-variabelen hieronder horen NIET in deze client-.env.
# Zet ze als environment variables in Netlify (Site settings > Environment variables):
#   GITHUB_TOKEN   = fine-grained token met Contents: read & write op de foto-repo
#   GITHUB_OWNER   = jouw GitHub-gebruikersnaam
#   GITHUB_REPO    = naam van de foto-repo (bv. aiden-portfolio-images)
#   GITHUB_BRANCH  = main   (optioneel)
